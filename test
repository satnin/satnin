#define NUM_OP_THREADS 1

class MyOrtAllocator
{
    static Ort::MemoryInfo MEMORY_INFO;
public:
    static void Init(Ort::Env& env)
    {
        Ort::AllocatorWithDefaultOptions def;
        OrtAllocator* al = def.operator OrtAllocator* ();
        // Setup OrtAllocator struct
        allocator_.version = al->version;
        allocator_.Alloc = &MyOrtAllocator::AllocThunk;
        allocator_.Reserve = &MyOrtAllocator::AllocThunk;
        allocator_.Free = &MyOrtAllocator::FreeThunk;
        allocator_.Info = &MyOrtAllocator::InfoThunk;
        allocator_.AllocOnStream = al->AllocOnStream;
        env.RegisterAllocator(&allocator_);
    }

    ~MyOrtAllocator()
    {
    }

    inline operator OrtAllocator* () {
        return &allocator_;
    }

    static OrtAllocator* Get() { return &allocator_; }
    static OrtMemoryInfo* Info() { return MEMORY_INFO; }
    
    static inline void* Alloc(size_t size) {
        void* p = std::malloc(size);
        std::cout << "[AI HEAP] Allocated @" << p << " " << size << " bytes\n";
        return p;
    }
    static inline void Free(void* p) {
        std::free(p);
        std::cout << "[AI HEAP] Freed     @" << p << "\n";
    }

private:
    static OrtAllocator allocator_;
    
    

    static void* ORT_API_CALL AllocThunk(OrtAllocator* this_, size_t size)
    {
        return Alloc(size);
    }

    static void ORT_API_CALL FreeThunk(OrtAllocator* this_, void* p)
    {
        Free(p);
    }

    static const OrtMemoryInfo* ORT_API_CALL InfoThunk(const OrtAllocator* this_)
    {
        return MEMORY_INFO;
    }
};
Ort::MemoryInfo MyOrtAllocator::MEMORY_INFO = Ort::MemoryInfo::CreateCpu(
    OrtDeviceAllocator, OrtMemTypeDefault);
OrtAllocator MyOrtAllocator::allocator_ = {};


struct MockedOrtAllocator : OrtAllocator {
    MockedOrtAllocator() {
        OrtAllocator::version = ORT_API_VERSION;
        OrtAllocator::Alloc = [](OrtAllocator* this_, size_t size) { return static_cast<MockedOrtAllocator*>(this_)->Alloc(size); };
        OrtAllocator::Free = [](OrtAllocator* this_, void* p) { static_cast<MockedOrtAllocator*>(this_)->Free(p); };
        OrtAllocator::Info = [](const OrtAllocator* this_) { return static_cast<const MockedOrtAllocator*>(this_)->Info(); };
        OrtAllocator::Reserve = [](OrtAllocator* this_, size_t size) { return static_cast<MockedOrtAllocator*>(this_)->Reserve(size); };
        OrtAllocator::GetStats = [](const OrtAllocator* this_, OrtKeyValuePairs** stats) noexcept -> OrtStatusPtr {
            *stats = static_cast<const MockedOrtAllocator*>(this_)->Stats();
            return nullptr;
            };
        OrtAllocator::AllocOnStream = nullptr;
        OrtAllocator::Shrink = nullptr;
        Ort::ThrowOnError(Ort::GetApi().CreateCpuMemoryInfo(OrtDeviceAllocator, OrtMemTypeDefault, &cpu_memory_info));
    }
    ~MockedOrtAllocator() {
        Ort::GetApi().ReleaseMemoryInfo(cpu_memory_info);
    }

    void* Alloc(size_t size) {
        return MyOrtAllocator::Alloc(size);
    };
    void Free(void* p) {
        MyOrtAllocator::Free(p);
    };
    const OrtMemoryInfo* Info() const {
        return MyOrtAllocator::Info();
    }
    void* Reserve(size_t size) {
        return MyOrtAllocator::Alloc(size);
    }
    OrtKeyValuePairs* Stats() const {
        Ort::KeyValuePairs kvps;

        auto str = std::to_string(num_allocations.load());
        kvps.Add("NumAllocs", str.c_str());

        str = std::to_string(num_reserve_allocations.load());
        kvps.Add("NumReserves", str.c_str());

        return kvps.release();
    }
    size_t NumAllocations() const {
        return num_allocations.load();
    }
    size_t NumReserveAllocations() const {
        return num_reserve_allocations.load();
    }

    void LeakCheck() {

    }

private:
    MockedOrtAllocator(const MockedOrtAllocator&) = delete;
    MockedOrtAllocator& operator=(const MockedOrtAllocator&) = delete;

    std::atomic<size_t> memory_inuse{ 0 };
    std::atomic<size_t> num_allocations{ 0 };
    std::atomic<size_t> num_reserve_allocations{ 0 };
    OrtMemoryInfo* cpu_memory_info;
};

class MyVectorAllocator {
public:
    void* allocate(size_t s) {
        return MyOrtAllocator::Alloc(s);
    }
    void free(void* p) {
        MyOrtAllocator::Free(p);
    }
};

class OnnxTensor {
    std::string name;
    std::vector<int64_t> shapes;
    ONNXTensorElementDataType type;
    std::shared_ptr<void> data_ptr;
    Ort::Value tensor;
    size_t nb_elements;

    static Ort::MemoryInfo MEMORY_INFO;
    template<typename T> inline void create_typed_tensor()
    {
        tensor = Ort::Value::CreateTensor<T>(
            MEMORY_INFO,
            (T*)data_ptr.get(),
            nb_elements,
            shapes.data(),
            shapes.size()
        );
    }
    inline size_t GetElementSize(ONNXTensorElementDataType type)
    {
        switch (type)
        {
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT:
            return sizeof(float);

        case ONNX_TENSOR_ELEMENT_DATA_TYPE_DOUBLE:
            return sizeof(double);

        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT8:
            return sizeof(int8_t);

        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT8:
            return sizeof(uint8_t);

        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT16:
            return sizeof(int16_t);

        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT16:
            return sizeof(uint16_t);

        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT32:
            return sizeof(int32_t);

        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT32:
            return sizeof(uint32_t);

        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT64:
            return sizeof(int64_t);

        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT64:
            return sizeof(uint64_t);

        default:
            throw std::runtime_error("Unsupported type");
        }
    }

    void create_tensor() {
        
        uint8_t* data = (uint8_t*)MyOrtAllocator::Alloc(nb_elements * GetElementSize(type));
        memset(data, 0, nb_elements * GetElementSize(type));
        data_ptr.reset(data, MyOrtAllocator::Free);

        switch (type)
        {
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UNDEFINED:
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT:
            create_typed_tensor<float>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT8:
            create_typed_tensor<uint8_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT8:
            create_typed_tensor<int8_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT16:
            create_typed_tensor<uint16_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT16:
            create_typed_tensor<int16_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT32:
            create_typed_tensor<int32_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT64:
            create_typed_tensor<int64_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_STRING:
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_BOOL:
            create_typed_tensor<bool>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT16:
            create_typed_tensor<uint16_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_DOUBLE:
            create_typed_tensor<double>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT32:
            create_typed_tensor<uint32_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT64:
            create_typed_tensor<uint64_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_COMPLEX64:
            create_typed_tensor<uint64_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_COMPLEX128:

            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_BFLOAT16:
            create_typed_tensor<uint16_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT8E4M3FN:
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT8E4M3FNUZ:
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT8E5M2:
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT8E5M2FNUZ:
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT4:
            create_typed_tensor<uint8_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT4:
            create_typed_tensor<uint8_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_FLOAT4E2M1:
            create_typed_tensor<uint8_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_UINT2:
            create_typed_tensor<uint8_t>();
            break;
        case ONNX_TENSOR_ELEMENT_DATA_TYPE_INT2:
            create_typed_tensor<uint8_t>();
            break;
        default:
            break;
        }
    }

public:
    OnnxTensor(std::string&& _name, std::vector<int64_t>&& _shapes, ONNXTensorElementDataType _type)
        : name(_name), shapes(_shapes), type(_type), nb_elements(0)
    {
        nb_elements = 1;
        for (const auto& el : shapes)
        {
            nb_elements *= el;
        }
        create_tensor();
    }

    inline void bind_as_input(Ort::IoBinding& io_binding) {
        io_binding.BindInput(name.c_str(), tensor);
    }
    inline void bind_as_output(Ort::IoBinding& io_binding) {
        io_binding.BindOutput(name.c_str(), tensor);
    }

    void print(std::ostream& o)const {

    }

    inline size_t get_nb_elements() const {
        return nb_elements;
    }

    inline size_t get_element_type() const {
        return 0;
    }

    inline Ort::Value& get_tensor() {
        return tensor;
    }
    void* operator new (size_t sz)
    {
        return MyOrtAllocator::Alloc(sz);
    }
    void operator delete (void* dp)
    {
        MyOrtAllocator::Free(dp);
    }
};

Ort::MemoryInfo OnnxTensor::MEMORY_INFO = Ort::MemoryInfo::CreateCpu(
    OrtArenaAllocator, OrtMemTypeDefault);


class OnnxModel {
    static Ort::Env env;
    Ort::SessionOptions session_options;
    size_t nb_inputs;
    size_t nb_outputs;
    Ort::Session session;
    Ort::IoBinding io_binding;
    std::vector<OnnxTensor> inputs;
    std::vector<OnnxTensor> outputs;
    static MockedOrtAllocator alloc;

public:
    static void Init() {
        //MyOrtAllocator::Init(env);
        env.RegisterAllocator(&alloc);
    }
    OnnxModel() : nb_inputs(0), nb_outputs(0), session(nullptr), io_binding(nullptr) {
        session_options.SetIntraOpNumThreads(NUM_OP_THREADS);
        session_options.SetGraphOptimizationLevel(GraphOptimizationLevel::ORT_ENABLE_ALL);
        //session_options.DisableCpuMemArena();
        session_options.AddConfigEntry("session.use_device_allocator_for_initializers", "1");
        session_options.AddConfigEntry(
            "session.use_env_allocators",
            "1");
    }
    void load() {
        static const auto path = L"resnet50v2.onnx";
        session = (Ort::Session(env, path, session_options));
        io_binding = Ort::IoBinding(session);

        nb_inputs = session.GetInputCount();
        nb_outputs = session.GetOutputCount();

        for (size_t i = 0; i < nb_inputs; i++) {
            auto name_alloc = session.GetInputNameAllocated(i, MyOrtAllocator::Get());
            std::string name = name_alloc.get();
            auto type_info = session.GetInputTypeInfo(i);
            auto tensor_info = type_info.GetTensorTypeAndShapeInfo();
            auto shape = tensor_info.GetShape();
            auto type = tensor_info.GetElementType();

            inputs.push_back(OnnxTensor(std::move(name), std::move(shape), type));
            inputs.back().bind_as_input(io_binding);
        }

        for (size_t i = 0; i < nb_outputs; i++) {
            auto name_alloc = session.GetOutputNameAllocated(i, MyOrtAllocator::Get());
            std::string name = name_alloc.get();
            auto type_info = session.GetOutputTypeInfo(i);
            auto tensor_info = type_info.GetTensorTypeAndShapeInfo();
            auto shape = tensor_info.GetShape();
            auto type = tensor_info.GetElementType();

            outputs.push_back(OnnxTensor(std::move(name), std::move(shape), type));
            outputs.back().bind_as_output(io_binding);
        }

    }

    size_t run() {
        session.Run(Ort::RunOptions{ nullptr }, io_binding);
        return 0;
    }

    inline size_t get_nb_inputs() const {
        return nb_inputs;
    }
    inline size_t get_nb_outputs() const {
        return nb_outputs;
    }

    inline OnnxTensor& input(size_t i) {
        return inputs[i];
    }
    inline OnnxTensor& output(size_t i) {
        return outputs[i];
    }
    inline std::vector<OnnxTensor>& Inputs() {
        return inputs;
    }
    inline std::vector<OnnxTensor>& Outputs() {
        return outputs;
    }

    void clean() {
        nb_inputs = 0;
        nb_outputs = 0;
        inputs.clear();
        outputs.clear();
    }

    void* operator new (size_t sz)
    {
        return MyOrtAllocator::Alloc(sz);
    }
    void operator delete (void* dp)
    {
        MyOrtAllocator::Free(dp);
    }
};

Ort::Env OnnxModel::env;
MockedOrtAllocator OnnxModel::alloc;


using namespace std;

int main() {
    OnnxModel::Init();
    OnnxModel* model = new OnnxModel();
    model->load();
    for (size_t i = 0; i < 150; i++)
    {
        model->run();
    }
    

    for (auto& output : model->Outputs()) {
        auto& out = output.get_tensor();
        auto info = out.GetTensorTypeAndShapeInfo();
        auto out_shape = info.GetShape();

        size_t total_len = output.get_nb_elements();
        float* data = out.GetTensorMutableData<float>();

        std::cout << "\nOutput " << " first values:\n";
        for (size_t j = 0; j < std::min<size_t>(10, total_len); j++) {
            std::cout << data[j] << " ";
        }
        std::cout << "\n";
    }

    delete model;
	return 0;
}
